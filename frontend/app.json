{
  "expo": {
    "name": "SquadPay",
    "slug": "squadpay",
    "owner": "getnuevetech",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "squadpay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.squadpay.app",
      "buildNumber": "2",
      "icon": "./assets/images/icon.png",
      "associatedDomains": [
        "applinks:squadpay.us",
        "applinks:www.squadpay.us",
        "applinks:getsquadpay.com",
        "applinks:www.getsquadpay.com"
      ],
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.us.squadpay"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhoneNumber",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePaymentInfo",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotosorVideos",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeDeviceID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality",
              "NSPrivacyCollectedDataTypePurposeAnalytics"
            ]
          }
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Scan receipts and QR codes to split bills",
        "NSPhotoLibraryUsageDescription": "Pick a receipt photo to split a bill",
        "NSContactsUsageDescription": "Invite friends from your contacts to a Squad",
        "NSFaceIDUsageDescription": "Securely unlock SquadPay and confirm payments",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "mailto",
          "tel",
          "sms"
        ]
      }
    },
    "android": {
      "package": "com.squadpay.app",
      "versionCode": 2,
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "squadpay.us",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "squadpay.us",
              "pathPrefix": "/group/"
            },
            {
              "scheme": "https",
              "host": "squadpay.us",
              "pathPrefix": "/payout/"
            },
            {
              "scheme": "https",
              "host": "www.squadpay.us",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "www.squadpay.us",
              "pathPrefix": "/group/"
            },
            {
              "scheme": "https",
              "host": "www.squadpay.us",
              "pathPrefix": "/payout/"
            },
            {
              "scheme": "https",
              "host": "getsquadpay.com",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "getsquadpay.com",
              "pathPrefix": "/group/"
            },
            {
              "scheme": "https",
              "host": "getsquadpay.com",
              "pathPrefix": "/payout/"
            },
            {
              "scheme": "https",
              "host": "www.getsquadpay.com",
              "pathPrefix": "/join/"
            },
            {
              "scheme": "https",
              "host": "www.getsquadpay.com",
              "pathPrefix": "/group/"
            },
            {
              "scheme": "https",
              "host": "www.getsquadpay.com",
              "pathPrefix": "/payout/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a receipt photo to split a bill",
          "cameraPermission": "Scan receipts to split bills with friends"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "./plugins/withWalletProvisioning",
        {
          "enabled": false
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.us.squadpay",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      },
      "walletProvisioning": {
        "enabled": false,
        "_comment": "Flip both this and the plugin arg to `true` once Stripe + Visa/Mastercard + Apple/Google approve our Push Provisioning program. No other frontend changes needed."
      }
    }
  }
}