{
  "expo": {
    "name": "SquadPay",
    "slug": "squadpay",
    "owner": "getnuevetech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "squadpay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.squadpay.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan receipts to split bills with friends",
        "NSPhotoLibraryUsageDescription": "Pick a receipt photo to split a bill",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.squadpay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#7C3AED"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a receipt photo to split a bill",
          "cameraPermission": "Scan receipts to split bills with friends"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    }
  }
}
